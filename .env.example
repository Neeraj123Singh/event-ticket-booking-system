# Copy to repo root `.env`. Optional: `packages/database/.env` or `apps/api/.env` for overrides.
DATABASE_URL="postgresql://ticketing:ticketing@localhost:5433/ticketing"

# API (apps/api/.env)
PORT=4000
ADMIN_API_KEY="dev-admin-key-change-me"
CORS_ORIGIN="http://localhost:3001,http://127.0.0.1:3001,http://localhost:3000"

# Optional pricing tuning (defaults: 1)
# PRICING_WEIGHT_TIME=1
# PRICING_WEIGHT_DEMAND=1
# PRICING_WEIGHT_INVENTORY=1

# Next.js (apps/web/.env.local)
NEXT_PUBLIC_API_URL="http://127.0.0.1:4000"
INTERNAL_API_URL="http://127.0.0.1:4000"
# Web UI runs on port 3001 by default (3000 is often taken by other tools).

# Vitest DB integration (optional; same DB as DATABASE_URL)
# TEST_DATABASE_URL="postgresql://ticketing:ticketing@localhost:5433/ticketing"
